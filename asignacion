<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmación de Asistencia y Pase Digital</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Montserrat', sans-serif;
        }

        body {
            background-color: #f3f4f6;
            color: #1f2937;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            max-width: 500px;
            width: 100%;
        }

        .card {
            background: #ffffff;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border: 1px solid #e5e7eb;
            text-align: center;
        }

        h1 {
            font-size: 22px;
            color: #111827;
            font-weight: 700;
            margin-bottom: 10px;
        }

        p.subtitle {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4b5563;
            margin-bottom: 6px;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 14px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            font-size: 15px;
            background-color: #f9fafb;
            transition: all 0.2s;
        }

        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: #1e3a8a;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }

        .btn-primary {
            display: block;
            width: 100%;
            background-color: #1e3a8a;
            color: white;
            border: none;
            padding: 15px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: background 0.2s;
            box-shadow: 0 4px 12px rgba(30, 58, 138, 0.2);
        }

        .btn-primary:hover {
            background-color: #111827;
        }

        /* Diseño del Boleto Digital (Oculto al inicio) */
        #seccion-boleto {
            display: none;
        }

        .ticket {
            background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
            color: white;
            border-radius: 20px;
            padding: 30px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            margin-top: 10px;
        }

        .ticket::before, .ticket::after {
            content: '';
            position: absolute;
            top: 45%;
            width: 24px;
            height: 24px;
            background-color: #f3f4f6;
            border-radius: 50%;
        }
        .ticket::before { left: -12px; }
        .ticket::after { right: -12px; }

        .ticket-title {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 1px;
            color: #fbeeac;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .ticket-label {
            font-size: 11px;
            text-transform: uppercase;
            color: #94a3b8;
            letter-spacing: 1px;
            margin-top: 10px;
        }

        .ticket-value {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .ticket-info-grid {
            display: flex;
            justify-content: space-between;
            border-top: 1px dashed rgba(255,255,255,0.2);
            border-bottom: 1px dashed rgba(255,255,255,0.2);
            padding: 15px 0;
            margin: 15px 0;
        }

        .info-item {
            flex: 1;
        }

        .info-item .val {
            font-size: 24px;
            font-weight: 700;
            color: #ffffff;
        }

        .qr-wrapper {
            background: white;
            padding: 12px;
            border-radius: 12px;
            display: inline-block;
            margin: 10px auto;
        }

        .btn-whatsapp {
            display: block;
            width: 100%;
            background-color: #25d366;
            color: white;
            border: none;
            padding: 15px;
            font-size: 15px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            text-decoration: none;
            margin-top: 20px;
            box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
        }

        .btn-whatsapp:hover {
            background-color: #20ba56;
        }
    </style>
</head>
<body>

<div class="container">
    
    <div id="seccion-formulario" class="card">
        <h1>Confirmación de Acceso</h1>
        <p class="subtitle">Introduce tus datos para generar tus pases digitales</p>
        
        <div class="form-group">
            <label for="input-familia">Apellido o Nombre de Familia</label>
            <input type="text" id="input-familia" placeholder="Ej. Pérez Mendoza" required>
        </div>

        <div class="form-group">
            <label for="select-asistentes">¿Cuántas personas asistirán?</label>
            <select id="select-asistentes">
                <option value="1">1 Persona</option>
                <option value="2">2 Personas</option>
                <option value="3">3 Personas</option>
                <option value="4" selected>4 Personas</option>
                <option value="5">5 Personas</option>
                <option value="6">6 Personas</option>
            </select>
        </div>

        <div class="form-group">
            <label for="input-telefono">Tu número de WhatsApp</label>
            <input type="text" id="input-telefono" placeholder="Ej. 5215512345678" value="521">
            <small style="font-size:11px; color:#6b7280; display:block; margin-top:4px;">Código de país + número (sin espacios).</small>
        </div>

        <button class="btn-primary" onclick="procesarAsistencia()">Confirmar y Generar Pases</button>
    </div>

    <div id="seccion-boleto" class="container">
        <div class="ticket">
            <div class="ticket-title">Pase Digital de Acceso</div>
            
            <div class="ticket-label">Familia / Invitado</div>
            <div class="ticket-value" id="ticket-familia">Familia Pérez</div>
            
            <div class="ticket-info-grid">
                <div class="info-item" style="border-right: 1px dashed rgba(255,255,255,0.2);">
                    <div class="ticket-label" style="margin:0">Asistentes</div>
                    <div class="val" id="ticket-asistentes">0</div>
                </div>
                <div class="info-item">
                    <div class="ticket-label" style="margin:0">Mesa Asignada</div>
                    <div class="val" id="ticket-mesa" style="color: #fbeeac;">-</div>
                </div>
            </div>
            
            <div class="qr-wrapper">
                <div id="qrcode"></div>
            </div>
            
            <div class="ticket-footer">
                <p>Muestra este código QR en la entrada</p>
                <p style="margin-top:2px; font-size:10px; color:#94a3b8;">Sistema Autónomo de Control</p>
            </div>
        </div>

        <button class="btn-whatsapp" onclick="enviarBoletoPorWhatsApp()">
            <i class="fab fa-whatsapp"></i> Recibir Boleto en mi WhatsApp
        </button>
    </div>

</div>

<script>
    // ==========================================
    // ASIGNACIÓN DE MESAS (TU BASE DE DATOS)
    // Escribe aquí los apellidos tal como los escribirían tus invitados (en minúsculas y sin acentos)
    // ==========================================
    const LISTADO_MESAS = {
        "perez": "Mesa 1",
        "perez mendoza": "Mesa 1",
        "martinez": "Mesa 2",
        "barrientos": "Mesa 3",
        "gonzalez": "Mesa 4",
        "rodriguez": "Mesa 5"
    };
    
    // Mesa por defecto si el apellido no está en la lista anterior
    const MESA_GENERAL = "Mesa General";

    // Variables globales para almacenar la sesión actual
    let datosInvitado Actual = {};

    // Función auxiliar para quitar acentos y dejar en minúsculas
    function limpiarTexto(texto) {
        return texto.toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .trim();
    }

    function procesarAsistencia() {
        const familiaOriginal = document.getElementById('input-familia').value.trim();
        const asistentes = document.getElementById('select-asistentes').value;
        const telefono = document.getElementById('input-telefono').value.replace(/[^0-9]/g, '');

        if (!familiaOriginal) {
            alert("Por favor, ingresa el nombre de tu familia.");
            return;
        }
        if (telefono.length < 10) {
            alert("Por favor, introduce un número de WhatsApp válido.");
            return;
        }

        // Buscar mesa de manera inteligente
        const familiaLimpia = limpiarTexto(familiaOriginal);
        let mesaAsignada = MESA_GENERAL;

        // Comprobar si coincide con nuestra base de datos
        if (LISTADO_MESAS[familiaLimpia]) {
            mesaAsignada = LISTADO_MESAS[familiaLimpia];
        } else {
            // Búsqueda parcial por si escriben "Familia Pérez" en vez de solo "Pérez"
            for (let clave in LISTADO_MESAS) {
                if (familiaLimpia.includes(clave)) {
                    mesaAsignada = LISTADO_MESAS[clave];
                    break;
                }
            }
        }

        // Guardar datos en el objeto global
        datosInvitadoActual = {
            familia: familiaOriginal,
            asistentes: asistentes,
            mesa: mesaAsignada,
            telefono: telefono
        };

        // Pintar los datos en el Boleto
        document.getElementById('ticket-familia').innerText = familiaOriginal;
        document.getElementById('ticket-asistentes').innerText = asistentes;
        document.getElementById('ticket-mesa').innerText = mesaAsignada;

        // Estructurar el contenido estricto dentro del QR
        const contenidoQR = `FAMILIA: ${familiaOriginal}\nASISTENTES: ${asistentes}\nMESA: ${mesaAsignada}\nSTATUS: CONFIRMADO`;

        // Generar Código QR
        const qrContainer = document.getElementById("qrcode");
        qrContainer.innerHTML = ""; 
        new QRCode(qrContainer, {
            text: contenidoQR,
            width: 180,
            height: 180,
            colorDark : "#0f172a",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });

        // Intercambiar pantallas de forma animada/limpia
        document.getElementById('seccion-formulario').style.display = 'none';
        document.getElementById('seccion-boleto').style.display = 'block';
    }

    function enviarBoletoPorWhatsApp() {
        const d = datosInvitadoActual;
        
        // Generar el link de reentrada por si quieren consultar el pase después
        const urlBase = window.location.href.split('?')[0];
        const urlPaseUnico = `${urlBase}?invitado=${encodeURIComponent(d.familia)}&pases=${d.asistentes}&mesa=${encodeURIComponent(d.mesa)}`;

        // Mensaje estructurado que se autoenviará el usuario
        const mensaje = `🎟️ *MI PASE DIGITAL DE ACCESO* 🎟️\n\n✅ *Confirmación Exitosa*\n\n👨‍👩‍👧‍👦 *Familia:* ${d.familia}\n👥 *Asistentes:* ${d.asistentes} ${d.asistentes == 1 ? 'persona' : 'personas'}\n📍 *Mesa Asignada:* ${d.mesa}\n\n🔗 Puedes volver a ver tu código QR de acceso desde este enlace en cualquier momento:\n${urlPaseUnico}\n\n¡Nos vemos en el evento! ✨`;

        const whatsappUrl = `https://api.whatsapp.com/send?phone=${d.telefono}&text=${encodeURIComponent(mensaje)}`;
        window.open(whatsappUrl, '_blank');
    }

    // Al cargar, verificar si entran directo o mediante link de reconsulta
    document.addEventListener("DOMContentLoaded", function() {
        const urlParams = new URLSearchParams(window.location.search);
        const invitadoUrl = urlParams.get('invitado');
        const pasesUrl = urlParams.get('pases');
        const mesaUrl = urlParams.get('mesa');

        // MODO CONSULTA: El invitado ya tiene pase y solo abrió el link desde su WhatsApp
        if (invitadoUrl && pasesUrl && mesaUrl) {
            document.getElementById('seccion-formulario').style.display = 'none';
            document.getElementById('seccion-boleto').style.display = 'block';
            document.querySelector('.btn-whatsapp').style.display = 'none'; // No necesita volver a enviárselo

            document.getElementById('ticket-familia').innerText = invitadoUrl;
            document.getElementById('ticket-asistentes').innerText = pasesUrl;
            document.getElementById('ticket-mesa').innerText = mesaUrl;

            const contenidoQR = `FAMILIA: ${invitadoUrl}\nASISTENTES: ${pasesUrl}\nMESA: ${mesaUrl}\nSTATUS: CONFIRMADO`;
            new QRCode(document.getElementById("qrcode"), {
                text: contenidoQR,
                width: 180,
                height: 180,
                colorDark : "#0f172a",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });
        }
    });
</script>

</body>
</html>
