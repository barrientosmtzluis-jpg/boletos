<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XVPau - Control de Mesas por Tickets</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background-color: #f4f4f9; }
        h1 { color: #2c3e50; text-align: center; margin-bottom: 30px; }
        .contenedor-mesas { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; padding: 10px; }
        .tarjeta-mesa { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); border-top: 5px solid #3498db; }
        .numero-mesa { font-size: 1.4rem; font-weight: bold; margin-bottom: 15px; color: #2c3e50; border-bottom: 2px solid #eee; padding-bottom: 5px; }
        .info { margin: 8px 0; color: #555; font-size: 1rem; }
        .lista-familias { margin-top: 15px; padding-left: 20px; font-size: 0.9rem; color: #666; background: #fafafa; padding: 10px; border-radius: 5px; }
        .titulo-familias { font-weight: bold; margin-bottom: 5px; color: #7f8c8d; }
    </style>
</head>
<body>

    <h1>XVPau: Monitoreo de Mesas</h1>
    <div id="mesas-grid" class="contenedor-mesas">Procesando tickets y mesas...</div>

    <!-- SDK de Firebase -->
    <script type="module">
        import { initializeApp } from "https://gstatic.com";
        import { getDatabase, ref, onValue } from "https://gstatic.com";

        // Configuración de tu proyecto
        const firebaseConfig = {
            apiKey: "TU_API_KEY",
            authDomain: "://firebaseapp.com",
            databaseURL: "https://firebaseio.com", 
            projectId: "xvpau",
            storageBucket: "://appspot.com",
            messagingSenderId: "TU_SENDER_ID",
            appId: "TU_APP_ID"
        };

        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);

        // Apuntamos a la raíz o al nodo donde guardas todos tus tickets
        const ticketsRef = ref(db, 'tickets'); // Cambia 'tickets' si tu nodo raíz se llama diferente

        onValue(ticketsRef, (snapshot) => {
            const grid = document.getElementById("mesas-grid");
            grid.innerHTML = ""; 

            const tickets = snapshot.val();

            if (!tickets) {
                grid.innerHTML = "<p>No se encontraron tickets registrados.</p>";
                return;
            }

            // Objeto temporal para agrupar los datos por mesa
            const mapaMesas = {};

            // 1. Recorrer cada ticket y agrupar la información
            Object.keys(tickets).forEach((ticketId) => {
                const tkt = tickets[ticketId];
                
                // Extraer los datos según tu estructura exacta
                const nombreMesa = tkt.mesa || "Sin Mesa Asignada";
                const pasesTotales = parseInt(tkt.pases_totales) || 0;
                const pasesUsados = parseInt(tkt.pases_usados) || 0;
                const pasesRestantes = parseInt(tkt.pases_restantes) || 0;
                const familia = tkt.familia || "Anónimo";

                // Si la mesa no existe en nuestro mapa, la inicializamos
                if (!mapaMesas[nombreMesa]) {
                    mapaMesas[nombreMesa] = {
                        capacidad_total: 0,
                        invitados_actuales: 0,
                        lugares_restantes: 0,
                        familias: []
                    };
                }

                // Acumular los totales de la mesa
                mapaMesas[nombreMesa].capacidad_total += pasesTotales;
                mapaMesas[nombreMesa].invitados_actuales += pasesUsados;
                mapaMesas[nombreMesa].lugares_restantes += pasesRestantes;
                
                // Guardar el nombre de la familia para mostrar quién está en esa mesa
                mapaMesas[nombreMesa].familias.push(`${familia} (${pasesUsados}/${pasesTotales} pases)`);
            });

            // 2. Dibujar las tarjetas en la pantalla ordenadas por nombre de mesa
            Object.keys(mapaMesas).sort().forEach((nombreMesa) => {
                const mesa = mapaMesas[nombreMesa];

                const tarjeta = document.createElement("div");
                tarjeta.className = "tarjeta-mesa";
                
                // Construir la lista de familias asignadas a esta mesa
                let htmlFamilias = `<div class="titulo-familias">Familias:</div>`;
                mesa.familias.forEach(f => {
                    htmlFamilias += `• ${f}<br>`;
                });

                tarjeta.innerHTML = `
                    <div class="numero-mesa">${nombreMesa}</div>
                    <div class="info">Lugares Asignados: <strong>${mesa.capacidad_total}</strong></div>
                    <div class="info">Invitados que ya llegaron: <strong>${mesa.invitados_actuales}</strong></div>
                    <div class="info">Lugares Libres por llegar: <strong style="color: #27ae60;">${mesa.lugares_restantes}</strong></div>
                    <div class="lista-familias">${htmlFamilias}</div>
                `;

                grid.appendChild(tarjeta);
            });
        });
    </script>
</body>
</html>
